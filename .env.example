# TenderScore environment configuration — copy to .env and fill in locally.
# Secrets live in environment variables only; .env is git-ignored (CLAUDE.md).

TENDERSCORE_ENVIRONMENT=development

# PostgreSQL 16 (matches docker-compose.yml defaults)
TENDERSCORE_DATABASE_URL=postgresql+psycopg://tenderscore:tenderscore@localhost:5432/tenderscore

# Object storage (MinIO locally; any S3-compatible API)
TENDERSCORE_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
TENDERSCORE_OBJECT_STORAGE_ACCESS_KEY=tenderscore
TENDERSCORE_OBJECT_STORAGE_SECRET_KEY=tenderscore-dev
TENDERSCORE_OBJECT_STORAGE_BUCKET=tenderscore-dev

# Only needed when building images behind a TLS-intercepting development
# proxy: set to the proxy's root CA certificate(s) in PEM form, e.g.
# export TENDERSCORE_BUILD_EXTRA_CA_CERT="$(awk 1 /path/to/proxy-ca/*.crt)"
# TENDERSCORE_BUILD_EXTRA_CA_CERT=

# Anthropic API (used from M4 via the llm_gateway only; no module calls the
# SDK directly). UK/EEA inference residency is a deployment constraint —
# endpoints stay configurable and are never hard-coded.
# ANTHROPIC_API_KEY=
